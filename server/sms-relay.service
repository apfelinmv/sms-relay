[Unit]
Description=SMS relay to Telegram
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=sms-relay
Group=sms-relay
EnvironmentFile=/etc/sms-relay.env
ExecStart=/usr/bin/python3 /opt/sms-relay/sms_relay.py
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/sms-relay
MemoryMax=64M

[Install]
WantedBy=multi-user.target
